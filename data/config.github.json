{
  "version": "1.0",
  "ai": {
    "provider": "custom",
    "model": "${HORIZON_AI_MODEL}",
    "base_url": "${HORIZON_AI_BASE_URL}",
    "api_key_env": "HORIZON_AI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "languages": ["zh", "en"],
    "analysis_concurrency": 3,
    "enrichment_concurrency": 2
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 100
    },
    "reddit": {
      "enabled": false,
      "subreddits": [
        {"subreddit": "AI", "sort": "hot", "fetch_limit": 20, "min_score": 10},
        {"subreddit": "MachineLearning", "sort": "hot", "fetch_limit": 15, "min_score": 20},
        {"subreddit": "LocalLLaMA", "sort": "hot", "fetch_limit": 15, "min_score": 10},
        {"subreddit": "OpenAI", "sort": "hot", "fetch_limit": 15, "min_score": 10},
        {"subreddit": "AutoGPT", "sort": "hot", "fetch_limit": 10, "min_score": 5},
        {"subreddit": "ClaudeAI", "sort": "hot", "fetch_limit": 15, "min_score": 5}
      ],
      "fetch_comments": 3
    },
    "rss": [
      {"name": "TechCrunch AI", "url": "https://techcrunch.com/category/artificial-intelligence/feed/", "category": "行业动态", "max_items": 5},
      {"name": "The Verge AI", "url": "https://www.theverge.com/ai-artificial-intelligence/rss.xml", "category": "AI产品", "enabled": false},
      {"name": "ArXiv ML", "url": "https://rss.arxiv.org/rss/cs.AI", "category": "学术", "max_items": 5},
      {"name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "category": "AI", "max_items": 10, "enabled": false},
      {"name": "LangChain Blog", "url": "https://blog.langchain.dev/feed/", "category": "AI工程", "enabled": false},
      {"name": "Google AI Blog", "url": "https://blog.google/technology/ai/rss/", "category": "AI", "enabled": false},
      {"name": "Anthropic Blog", "url": "https://www.anthropic.com/feed.xml", "category": "AI", "enabled": false},
      {"name": "OpenAI Blog", "url": "https://openai.com/blog/rss.xml", "category": "AI"},
      {"name": "Mistral AI Blog", "url": "https://mistral.ai/news/feed.xml", "category": "AI", "enabled": false},
      {"name": "智谱AI", "url": "https://www.zhipuai.cn/feed.xml", "category": "AI国内"}
    ],
    "github": [
      {"type": "repo_releases", "owner": "langchain-ai", "repo": "langchain"},
      {"type": "repo_releases", "owner": "langchain-ai", "repo": "langgraph"},
      {"type": "repo_releases", "owner": "crewAIInc", "repo": "crewAI"},
      {"type": "repo_releases", "owner": "Significant-Gravitas", "repo": "AutoGPT"},
      {"type": "repo_releases", "owner": "microsoft", "repo": "autogen"},
      {"type": "repo_releases", "owner": "anthropics", "repo": "claude-code"},
      {"type": "repo_releases", "owner": "anthropics", "repo": "anthropic-cookbook"},
      {"type": "repo_releases", "owner": "openai", "repo": "openai-cookbook"},
      {"type": "repo_releases", "owner": "n8n-io", "repo": "n8n"},
      {"type": "repo_releases", "owner": "chatchat-space", "repo": "Langchain-Chatchat"}
    ]
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "max_items": 30,
    "category_groups": {
      "learn": {
        "name": "深度学习优先",
        "limit": 12,
        "categories": ["AI工程", "学术", "AI Agent", "开源"]
      },
      "topic": {
        "name": "选题优先",
        "limit": 12,
        "categories": ["AI", "AI产品", "AI国内", "行业动态"]
      },
      "tool": {
        "name": "工具观察",
        "limit": 6,
        "categories": ["AI工具", "Obsidian+AI"]
      }
    },
    "default_group": "other",
    "default_group_limit": 6
  }
}
