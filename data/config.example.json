{
  "version": "1.0",
  "ai": {
    "provider": "custom",
    "model": "${HORIZON_AI_MODEL}",
    "base_url": "${HORIZON_AI_BASE_URL}",
    "api_key_env": "HORIZON_AI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "languages": ["zh", "en"],
    "analysis_concurrency": 3,
    "enrichment_concurrency": 2
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {
        "name": "TechCrunch AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "first_hand_news",
        "max_items": 8
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "first_hand_news",
        "max_items": 5
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "first_hand_news",
        "max_items": 5
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "practice_insight",
        "max_items": 5
      },
      {
        "name": "Chip Huyen",
        "url": "https://huyenchip.com/feed.xml",
        "enabled": true,
        "category": "practice_insight",
        "max_items": 3
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "practice_insight",
        "max_items": 5
      }
    ],
    "github": [
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "claude-code",
        "enabled": true,
        "category": "practice_insight"
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-cookbook",
        "enabled": true,
        "category": "practice_insight"
      },
      {
        "type": "repo_releases",
        "owner": "n8n-io",
        "repo": "n8n",
        "enabled": true,
        "category": "practice_insight"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "AI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 10
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 3
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "equities",
          "symbols": ["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA"]
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "quota_fill_score_threshold": 5.0,
    "time_window_hours": 24,
    "max_items": 20,
    "category_groups": {
      "first_hand_news": {
        "name": "一手资讯速递",
        "limit": 15,
        "categories": ["first_hand_news"]
      },
      "practice_insight": {
        "name": "实战与专家洞察",
        "limit": 5,
        "categories": ["practice_insight"]
      }
    },
    "default_group": "other",
    "default_group_limit": 0
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
