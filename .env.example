# Environment Variables

# AI API Keys (configure at least one)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
GOOGLE_API_KEY=xxx
MINIMAX_API_KEY=xxx
DASHSCOPE_API_KEY=xxx
DOUBAO_API_KEY=xxx
DEEPSEEK_API_KEY=xxx

# Custom OpenAI-compatible model gateway
# Use this for self-hosted gateways, free-model gateways, OpenRouter, SiliconFlow,
# or any provider that exposes an OpenAI-compatible /v1 chat completions API.
HORIZON_AI_API_KEY=xxx
HORIZON_AI_BASE_URL=https://your-openai-compatible-gateway/v1
HORIZON_AI_MODEL=your-model-name

# WebHook Url (optional for sending notifications)
HORIZON_WEBHOOK_URL=https://xxx

# GitHub Token (optional but recommended for higher rate limits)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
GITHUB_TOKEN=ghp_xxx

# GitHub Actions optional token secret for the public publishing workflow.
# If omitted, .github/workflows/daily-summary.yml falls back to github.token.
HORIZON_GITHUB_TOKEN=ghp_xxx

# Daily audio brief TTS.
# Recommended provider for Chinese audio: Tencent Cloud TTS.
HORIZON_TTS_PROVIDER=tencent
TENCENTCLOUD_SECRET_ID=AKIDxxx
TENCENTCLOUD_SECRET_KEY=xxx
HORIZON_TENCENT_TTS_REGION=ap-guangzhou
HORIZON_TENCENT_TTS_VOICE_TYPE=101001
HORIZON_TENCENT_TTS_CODEC=mp3
HORIZON_TENCENT_TTS_SPEED=0
HORIZON_TENCENT_TTS_VOLUME=0
HORIZON_TENCENT_TTS_SAMPLE_RATE=16000
HORIZON_TENCENT_TTS_SEGMENT_RATE=0
HORIZON_TENCENT_TTS_EMOTION_CATEGORY=news
HORIZON_TENCENT_TTS_EMOTION_INTENSITY=80
HORIZON_TTS_KEEP_DAYS=7

# Apify Token (required for Twitter scraping)
# Get yours at https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxx
